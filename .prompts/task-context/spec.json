  "qa_and_tooling_integration": {
    "objective": "Provide direct operational linkage between project records and accessibility validation tooling.",
    "integration_architecture": {
      "execution_model": "Asynchronous queued execution with structured result persistence",
      "required_components": [
        "Tool registry",
        "Adapter abstraction",
        "Execution broker",
        "Artifact staging area",
        "Structured result parser",
        "Persistent execution logs",
        "Retry and timeout handling"
      ]
    },
    "supported_tools": [
      {
        "name": "DAISY Ace",
        "purpose": "EPUB accessibility validation",
        "integration_method": "CLI adapter",
        "required_outputs": [
          "JSON report",
          "HTML report",
          "Issue severity normalization"
        ]
      },
      {
        "name": "EPUBCheck",
        "purpose": "EPUB conformance validation",
        "integration_method": "CLI adapter",
        "required_outputs": [
          "Validation results",
          "Error normalization",
          "Manifest extraction"
        ]
      },
      {
        "name": "Liblouis",
        "purpose": "Braille translation",
        "integration_method": "Library wrapper or subprocess adapter",
        "required_outputs": [
          "Translation logs",
          "Table metadata",
          "Translation confidence metadata"
        ]
      },
      {
        "name": "BRLTTY",
        "purpose": "Braille display testing",
        "integration_method": "CLI adapter",
        "required_outputs": [
          "Compatibility test logs",
          "Device mapping data"
        ]
      },
      {
        "name": "Pandoc",
        "purpose": "Document conversion",
        "integration_method": "CLI adapter",
        "required_outputs": [
          "Conversion logs",
          "Artifact lineage tracking"
        ]
      },
      {
        "name": "DAISY Pipeline 2",
        "purpose": "Accessible publishing automation",
        "integration_method": "REST and CLI hybrid adapter",
        "required_outputs": [
          "Pipeline execution metadata",
          "Artifact lineage",
          "Transformation history"
        ]
      }
    ],
    "direct_linkage_requirements": {
      "job_association": [
        "Every QA run must map to a job record",
        "Every QA result must map to specific source artifacts",
        "Execution metadata must include operator, timestamp, and tool version"
      ],
      "artifact_linkage": [
        "Generated outputs must preserve lineage references",
        "Derivative files must retain provenance metadata",
        "QA findings must link directly to source files"
      ],
      "ui_requirements": [
        "Run tooling directly from job pages",
        "Display structured validation summaries",
        "Provide issue drill-down views",
        "Expose raw logs and normalized findings",
        "Allow rerun and comparison operations"
      ],
      "storage_requirements": [
        "Persist raw tool outputs",
        "Persist normalized issue models",
        "Track execution duration",
        "Track exit codes",
        "Track environment metadata"
      ]
    },
    "normalized_issue_schema": {
      "required_fields": [
        "issue_id",
        "job_id",
        "tool_name",
        "severity",
        "category",
        "message",
        "source_file",
        "line_reference",
        "recommendation",
        "detected_timestamp"
      ]
    }
